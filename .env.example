# Server Port (defaults to 3001 if not set)
PORT=3001

# Postmark Email Configuration
# Get your Server API Token from: https://account.postmarkapp.com → Servers → Your Server → API Tokens
POSTMARK_API_TOKEN=your_postmark_server_api_token_here

# From email (must be a verified Sender Signature in Postmark)
FROM_EMAIL=noreply@congenie.com

# Recipient email for RFP submissions (on Services Page)
RFP_TO_EMAIL=arif@letuscode.com

# Recipient email for Contact Form submissions (on Contact Page)
CONTACT_TO_EMAIL=mayank@etechlogix.com

# Fallback recipient email (used if specific form emails are not set)
TO_EMAIL=arif@letuscode.com
